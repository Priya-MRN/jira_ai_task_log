# JIRA AI Bridge — example environment configuration.
# Copy this file to ".env" and fill in your JIRA Cloud credentials.
# If you leave these blank, the bridge runs fully locally in MOCK mode.

# --- JIRA Cloud credentials (all optional) ---------------------------------
# Your JIRA site, e.g. https://your-team.atlassian.net
JIRA_BASE_URL=

# The email you log into JIRA with.
JIRA_EMAIL=

# Create one at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# The project key new issues are created under (e.g. ENG, OPS, PROJ).
JIRA_PROJECT_KEY=LOCAL

# --- Behaviour -------------------------------------------------------------
# Path to the local worklog SQLite database.
# JIRA_BRIDGE_DB=worklog.db

# Force the mock client even when credentials are present (1/true/yes).
JIRA_BRIDGE_FORCE_MOCK=

# Automatically push events to JIRA on capture (default true).
JIRA_BRIDGE_AUTO_SYNC=true

# Default git watcher poll interval, in seconds.
JIRA_BRIDGE_GIT_INTERVAL=60

# Default dashboard port.
JIRA_BRIDGE_PORT=5050
